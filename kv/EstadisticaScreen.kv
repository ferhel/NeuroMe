<EstadisticaScreen>:
    name: "estadistica_screenn"
    BoxLayout:
        orientation: "vertical"
        canvas.before:
            Color:
                rgba: 1, 1, 1, 1  # Color blanco
            Rectangle:
                pos: self.pos
                size: self.size
        Label:
            text: "Estadísticas"
            font_size: 32
            color: "black"
            halign: "center"
            size_hint_y: None

        Button:
            text: "Descripciones generales"
            on_press: app.desc_generales()

        Button:
            text: "Mapa de Calor"
            on_press: app.Mapa_calor()

        Button:
            text: "Comparación de MMSE por grupos de edad"
            on_press: app.MMSE_grupos_edad()

        Button:
            text: "Volver al Inicio"
            on_press: app.root.current = "main"

