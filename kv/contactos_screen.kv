<ContactosScreen>:
    name: "contactos_screen"
    BoxLayout:
        orientation: "vertical"
        canvas.before:
            Color:
                rgba: 1, 1, 1, 1  # Color blanco
            Rectangle:
                pos: self.pos
                size: self.size
        Label:
            text: "Pantalla de Contactos"
            font_size: 32
            color: "black"
            halign: "center"
            size_hint_y: None
            height: 100


        Button:
            text: "Volver al Inicio"
            on_press: app.root.current = "main"