
#: include kv/historial_screen.kv

<MyScreenManager>:
    MainScreen:
    HistorialScreen:

<MainScreen>:
    name: "main"
    BoxLayout:
        orientation: "vertical"
        canvas.before:
            Color:
                rgba: 1, 1, 1, 1  # Color blanco
            Rectangle:
                pos: self.pos
                size: self.size
        Label:
            text: "¡Hola, usuario!"
            font_size: 24
            halign: "center"
            color: "black"

        BoxLayout:
            orientation: "horizontal"
            size_hint_y: None
            height: 50

            Button:
                text: "Historial"
                on_press: app.root.current = "historial_screen"
